    @staticmethod
    def lsys():
        output_file = "system_report.txt"
        def run(cmd):
            return tool.cmd(cmd, capture=True) or ""
        with open(output_file, "w") as f:
            f.write("=== SYSTEM REPORT ===\n")
            ping = ["ping", "-n", "4", "google.com"] if IS_WINDOWS else ["ping", "-c", "4", "google.com"]
            f.write(run(ping))
            cpu = ["wmic", "cpu", "get", "name"] if IS_WINDOWS else ["uname", "-p"]
            f.write(run(cpu))
            mem = ["systeminfo"] if IS_WINDOWS else ["free", "-h"]
            f.write(run(mem))
            f.write(run(["whoami"]))
        print(f"Saved to {output_file}")
    @staticmethod
    def dirmap():
        output_file = "directory_map.txt"
        if IS_WINDOWS:
            roots = [f"{d}:/" for d in string.ascii_uppercase if os.path.exists(f"{d}:/")]
        else:
            roots = ["/"]
        print(f"[*] Mapping directories from {roots} ...")
        with open(output_file, "w", encoding="utf-8") as f:
            for root in roots:
                base_path = Path(root).resolve()
                f.write(f"{base_path}/\n")  # Write the base path
                base_path_len = len(base_path.parts)
                for current_path, dirs, files in os.walk(base_path, topdown=True, followlinks=False):
                    try:
                        current_path = Path(current_path)
                        rel_parts = current_path.parts[base_path_len:]
                        level = len(rel_parts)
                        indent = "│   " * (level - 1) + ("├── " if level > 0 else "")
                        dir_name = current_path.name if level > 0 else str(current_path)
                        f.write(f"{indent}{dir_name}/\n")
                        subindent = "│   " * level + "├── "
                        for name in files:
                            f.write(f"{subindent}{name}\n")
                    except Exception as e:
                        sys.stderr.write(f"Error accessing {current_path}: {e}\n")
        print(f"[+] Directory map saved to {output_file}")
