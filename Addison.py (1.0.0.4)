class SafeCalc:
    OPS = {
        ast.Add: operator.add,
        ast.Sub: operator.sub,
        ast.Mult: operator.mul,
        ast.Div: operator.truediv,
        ast.Mod: operator.mod,
        ast.Pow: operator.pow,
        ast.FloorDiv: operator.floordiv,
        ast.USub: operator.neg,
        ast.UAdd: operator.pos,
    }
    @staticmethod
    def eval_expr(expr):
        node = ast.parse(expr, mode="eval").body
        return SafeCalc._eval(node)
    @staticmethod
    def _eval(node):
        if isinstance(node, ast.BinOp):
            return SafeCalc.OPS[type(node.op)](
                SafeCalc._eval(node.left),
                SafeCalc._eval(node.right)
            )
        elif isinstance(node, ast.UnaryOp):
            return SafeCalc.OPS[type(node.op)](SafeCalc._eval(node.operand))
        elif isinstance(node, ast.Constant):
            if isinstance(node.value, (int, float)):
                return node.value
            raise ValueError("Only numbers allowed")
        else:
            raise TypeError(f"Unsupported expression: {ast.dump(node)}")
class tool:
    @staticmethod
    def getInput(ios, arg):
        val = input(arg)
        return int(val) if ios else val
    @staticmethod
    def cmd(args, capture=False):
        try:
            args = safe_split(args)

            result = subprocess.run(
                args,
                capture_output=capture,
                text=True,
                shell=False
            )
            if capture:
                return result.stdout
        except Exception as e:
            print(f"[ERROR] Command failed: {e}")
    @staticmethod
    def mdir():
        dname = tool.getInput(False, "Directory name please: ")
        try:
            Path(dname).mkdir(parents=True, exist_ok=True)
            print(f"OK, created: '{dname}'\nPATH: {os.getcwd()}")
        except Exception as e:
            print(f"Error: {e}")
    @staticmethod
    def read(fname):
        try:
            with open(fname, "r", encoding="utf-8") as f:
                print(f.read())
        except FileNotFoundError:
            print("File not found!")
    @staticmethod
    def write(fname):
