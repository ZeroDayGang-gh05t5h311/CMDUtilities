#!/usr/bin/python3
import subprocess,logging,psutil,ipaddress,os,time,argparse,json,csv
from logging.handlers import RotatingFileHandler
from concurrent.futures import ThreadPoolExecutor
import multiprocessing
from threading import Lock
from collections import defaultdict, deque
RATE_LIMIT_SECONDS = 60
MAX_WORKERS = max(2, multiprocessing.cpu_count() * 2)
BASELINE_FILE = "baseline.json"
MAX_BASELINE_ENTRIES = 10000
# Heuristic tuning
FREQ_WINDOW = 60
FREQ_THRESHOLD = 20
BEACON_MIN_SAMPLES = 5
BEACON_VARIANCE_THRESHOLD = 2  # seconds tolerance
SUSPICIOUS_PORTS = {4444, 5555, 6666, 1337, 9001}
class NetworkMonitor:
    def __init__(self, terminal_output=False, config=None, learn=False,
                 export_csv=None, export_json=None):
        self.learn = learn
        self.export_csv = export_csv
        self.export_json = export_json
        self.alerts = []
        self.alert_cache = {}
        self.proc_cache = {}
        self.lock = Lock()
        self.ALLOWED_PORTS = {22, 53, 80, 443}
        self.ALLOWED_IP_RANGES = [
            ipaddress.ip_network("127.0.0.0/8"),
            ipaddress.ip_network("192.168.1.0/24"),
            ipaddress.ip_network("::1/128")
        ]
        self.ALLOWED_PROCESSES = {}
        self.baseline = {"connections": set(), "process_ports": set()}
        # Heuristic state
        self.connection_history = defaultdict(deque)
        self.beacon_history = defaultdict(deque)
        self.load_baseline()
        if config:
            self.load_config(config)
        self.terminal_output = terminal_output
        root = logging.getLogger()
        if not root.handlers:
            formatter = logging.Formatter(
                "%(asctime)s - %(levelname)s - %(message)s"
            )
            try:
                handler = RotatingFileHandler(
                    "/var/log/network_monitor.log",
                    maxBytes=5 * 1024 * 1024,
                    backupCount=5
                )
            except PermissionError:
                handler = RotatingFileHandler(
                    "network_monitor.log",
                    maxBytes=5 * 1024 * 1024,
                    backupCount=5
                )
            handler.setFormatter(formatter)
            root.setLevel(logging.INFO)
            root.addHandler(handler)
            if terminal_output:
                console = logging.StreamHandler()
                console.setFormatter(formatter)
                root.addHandler(console)
    def load_config(self, path):
        with open(path, encoding="utf-8") as f:
            cfg = json.load(f)
        self.ALLOWED_PORTS |= set(cfg.get("ports", []))
        self.ALLOWED_IP_RANGES.extend(
            ipaddress.ip_network(n) for n in cfg.get("ip_ranges", [])
        )
        self.ALLOWED_PROCESSES = cfg.get("processes", {})
    def load_baseline(self):
        if os.path.exists(BASELINE_FILE):
            with open(BASELINE_FILE, encoding="utf-8") as f:
                data = json.load(f)
                self.baseline["connections"] = set(data.get("connections", []))
                self.baseline["process_ports"] = set(data.get("process_ports", []))

    def save_baseline(self):
        with open(BASELINE_FILE, "w", encoding="utf-8") as f:
            json.dump(
                {
                    "connections": list(self.baseline["connections"])[:MAX_BASELINE_ENTRIES],
                    "process_ports": list(self.baseline["process_ports"])[:MAX_BASELINE_ENTRIES]
                },
                f,
                indent=2
            )

    def rate_limited(self, key):
        now = time.time()
        with self.lock:
            last = self.alert_cache.get(key, 0)
            if now - last < RATE_LIMIT_SECONDS:
                return True
            self.alert_cache[key] = now
        return False

    @staticmethod
    def clean_ip(ip):
        return ip.split("%", 1)[0].strip("[]")

    def classify_ip(self, ip):
        try:
            addr = ipaddress.ip_address(ip)
            if addr.is_private:
                return "private"
            if addr.is_loopback:
                return "loopback"
            if addr.is_multicast:
                return "multicast"
            if addr.is_reserved:
                return "reserved"
            return "public"
        except Exception:
            return "unknown"

    def get_context(self, ip):
        ip_class = self.classify_ip(ip)
        if ip_class == "loopback":
            return "LOOPBACK"
        if ip_class == "private":
            return "PRIVATE_LAN"
        if ip_class == "multicast":
            return "MULTICAST"
        if ip_class == "reserved":
            return "RESERVED"
        if ip_class == "public":
            return "PUBLIC"
        return "UNKNOWN"
    def is_ip_allowed(self, ip):
        try:
            addr = ipaddress.ip_address(self.clean_ip(ip))
            return any(addr in net for net in self.ALLOWED_IP_RANGES)
        except ValueError:
            return False
    @staticmethod
    def get_ss(args):
        try:
            r = subprocess.run(
                ["ss"] + args + ["-H"],
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                check=False
            )
            return r.stdout.decode().splitlines()
        except Exception:
            return []
    def _record_alert(self, typ, msg, key, context=None):
        if self.rate_limited(key):
            return
        prefix = f"[{context}]" if context else "[UNKNOWN]"
        logging.warning(f"{prefix} {msg}")
        with self.lock:
            self.alerts.append((time.time(), typ, f"{prefix} {msg}"))
    def process_connection(self, line):
        cols = line.split()
        if len(cols) < 5:
            return
        proto = cols[0]
        dest = cols[4]
        if ":" not in dest:
            return
        ip, port = dest.rsplit(":", 1)
        ip = self.clean_ip(ip)
        if not port.isdigit():
            return
        port = int(port)
        key = f"{proto}:{ip}:{port}"
        now = time.time()
        context = self.get_context(ip)
        # Learn mode
        if self.learn:
            with self.lock:
                if len(self.baseline["connections"]) < MAX_BASELINE_ENTRIES:
                    self.baseline["connections"].add(key)
            return
        # FIRST SEEN (ALL TRAFFIC)
        if key not in self.baseline["connections"]:
            self._record_alert(
                "first_seen",
                f"First-seen connection {proto} {ip}:{port}",
                key,
                context
            )
        # Frequency anomaly (ALL TRAFFIC)
        hist = self.connection_history[key]
        hist.append(now)
        while hist and now - hist[0] > FREQ_WINDOW:
            hist.popleft()
        if len(hist) > FREQ_THRESHOLD:
            self._record_alert(
                "frequency",
                f"High frequency connection {ip}:{port} ({len(hist)}/min)",
                key,
                context
            )
        # Beaconing (ALL TRAFFIC)
        bh = self.beacon_history[key]
        bh.append(now)
        if len(bh) >= BEACON_MIN_SAMPLES:
            intervals = [bh[i] - bh[i - 1] for i in range(1, len(bh))]
            avg = sum(intervals) / len(intervals)
            variance = sum(abs(i - avg) for i in intervals) / len(intervals)
            if variance < BEACON_VARIANCE_THRESHOLD:
                self._record_alert(
                    "beaconing",
                    f"Beaconing detected to {ip}:{port} (interval ~{avg:.1f}s)",
                    key,
                    context
                )
            if len(bh) > 20:
                bh.popleft()
        # Geo / exposure classification (ALL TRAFFIC)
        if port not in self.ALLOWED_PORTS:
            self._record_alert(
                "geo",
                f"Connection to {context} IP {ip}:{port}",
                key,
                context
            )
    def process_process(self, line):
        if "pid=" not in line:
            return
        try:
            pid = int(line.split("pid=", 1)[1].split(",", 1)[0])

            if pid not in self.proc_cache:
                self.proc_cache[pid] = psutil.Process(pid).name()
            pname = self.proc_cache[pid]
        except Exception:
            return
        cols = line.split()
        if len(cols) < 5:
            return
        dest = cols[4]
        if ":" not in dest:
            return
        port = dest.rsplit(":", 1)[-1]
        if not port.isdigit():
            return
        port = int(port)
        key = f"{pname}:{port}"
        if self.learn:
            with self.lock:
                if len(self.baseline["process_ports"]) < MAX_BASELINE_ENTRIES:
                    self.baseline["process_ports"].add(key)
            return
        if port in SUSPICIOUS_PORTS:
            self._record_alert(
                "suspicious_port",
                f"Process {pname} using suspicious port {port}",
                key,
                "PROCESS"
            )
        if key not in self.baseline["process_ports"]:
            self._record_alert(
                "process_anomaly",
                f"Process {pname} new port usage {port}",
                key,
                "PROCESS"
            )
    def run(self, continuous=False, once=False, duration=None):
        is_root = (os.geteuid() == 0)
        def once_scan():
            conns = self.get_ss(["-tun"])
            procs = self.get_ss(["-tunp"]) if is_root else []
            if len(conns) < 100:
                for l in conns:
                    self.process_connection(l)
                for l in procs:
                    self.process_process(l)
            else:
                with ThreadPoolExecutor(MAX_WORKERS) as ex:
                    for l in conns:
                        ex.submit(self.process_connection, l)
                    for l in procs:
                        ex.submit(self.process_process, l)
        start_time = time.time()
        if once:
            once_scan()
            self._print_terminal_summary()
            if self.learn:
                self.save_baseline()
            return
        if continuous:
            while True:
                once_scan()
                if duration and (time.time() - start_time) >= duration:
                    break
                time.sleep(10)
        else:
            once_scan()
        if self.learn:
            self.save_baseline()
        if self.export_csv:
            with open(self.export_csv, "w", newline="", encoding="utf-8") as f:
                w = csv.writer(f)
                for ts, typ, msg in self.alerts:
                    w.writerow([ts, typ, msg])
        if self.export_json:
            with open(self.export_json, "w", encoding="utf-8") as f:
                json.dump(self.alerts, f, indent=2)
    def _print_terminal_summary(self):
        if not self.alerts:
            print("\nNo alerts detected.")
            return
        print("\n=== Network Monitor Alerts Summary ===")
        for i, (_, _, a) in enumerate(self.alerts, 1):
            print(f"{i}. {a}")
        print("=====================================\n")
def main():
    p = argparse.ArgumentParser(
        description="Network connection and process monitor with baseline learning"
    )
    p.add_argument("-c", "--continuous", action="store_true")
    p.add_argument("--terminal", action="store_true")
    p.add_argument("--config")
    p.add_argument("--learn", action="store_true")
    p.add_argument("--export-csv")
    p.add_argument("--export-json")
    p.add_argument("--once", action="store_true")
    p.add_argument("--duration", type=int)
    args = p.parse_args()
    m = NetworkMonitor(
        terminal_output=args.terminal,
        config=args.config,
        learn=args.learn,
        export_csv=args.export_csv,
        export_json=args.export_json
    )
    m.run(
        continuous=args.continuous,
        once=args.once,
        duration=args.duration
    )
if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        exit()
